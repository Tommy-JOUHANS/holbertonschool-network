#!/usr/bin/env bash
# listening_ports.sh — show all listening sockets with PID and program name

set -euo pipefail

# Require root or sudo for full PID visibility
if [[ $EUID -ne 0 ]]; then
  echo "Note: run as root (sudo) to see PIDs for all processes." >&2
  echo ""
fi

# Prefer ss (modern), fall back to netstat
if command -v ss &>/dev/null; then
  echo "Proto  Local Address          PID/Program"
  echo "-----  ---------------------  -----------"
  ss -tlnup 2>/dev/null \
    | awk 'NR > 1 {
        proto = $1
        local = $5
        pid_prog = $NF

        # Extract pid and name from users:(("name",pid=123,fd=4))
        if (match(pid_prog, /\(\("([^"]+)",pid=([0-9]+)/, arr)) {
          name = arr[1]
          pid  = arr[2]
          info = pid "/" name
        } else {
          info = "-"
        }

        printf "%-6s %-22s %s\n", proto, local, info
      }'
elif command -v netstat &>/dev/null; then
  echo "Proto  Local Address          PID/Program"
  echo "-----  ---------------------  -----------"
  netstat -tlnp 2>/dev/null \
    | awk 'NR > 2 {
        proto = $1
        local = $4
        pid_prog = $NF
        printf "%-6s %-22s %s\n", proto, local, pid_prog
      }'
else
  echo "Error: neither 'ss' nor 'netstat' found. Install iproute2 or net-tools." >&2
  exit 1
fi